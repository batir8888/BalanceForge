DOXYFILE_ENCODING      = UTF-8
PROJECT_NAME           = "BalanceForge"
PROJECT_NUMBER         = "1.0"
PROJECT_BRIEF          = "Balance Table Management System for Unity"

OUTPUT_DIRECTORY       = docs

OUTPUT_LANGUAGE        = Russian

# Оптимизация под C-подобные языки (Doxygen использует Java-флаг для C#)
OPTIMIZE_OUTPUT_JAVA   = YES

EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES

CASE_SENSE_NAMES       = YES

INPUT                  = .

RECURSIVE              = YES

EXCLUDE_PATTERNS       = */obj/* \
                         */bin/* \
                         */.git/* \
                         */.vs/*

GENERATE_LATEX         = YES
LATEX_OUTPUT           = latex
LATEX_CMD_NAME         = latex
MAKEINDEX_CMD_NAME     = makeindex
COMPACT_LATEX          = NO

PAPER_TYPE             = a4

PDF_HYPERLINKS         = YES
USE_PDFLATEX           = YES

SHOW_GROUPED_MEMB_INC  = YES
GENERATE_HTML          = YES
HTML_OUTPUT            = html
ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = YES
EXPAND_ONLY_PREDEF     = YES